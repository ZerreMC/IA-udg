(define (problem pb_avancat1a)
    (:domain magabot_avancat)
    (:objects
        r1 r2 - robot
        pkg1 pkg2 pkg3 pkg4 p_end - package
        l11 l12 l13 l14 l15 l16 l21 l26 l31 l32 l36 l42 l44 l45 l46 l52 l53 l54 l64 l65 - location
        e1 e2 - shelf
        d - dispenser
        c - charger
    )
    (:init
        (at r1 l16)
        (at r2 l42)
        (clear r1)
        (clear r2)
        (occupied l16)
        (occupied l42)

        (= (battery r1) 20)
        (= (battery r2) 20)
        (= (max-battery r1) 50)
        (= (max-battery r2) 50)
        (= (load r1) 0)
        (= (load r2) 0)
        (= (max-load r1) 10)
        (= (max-load r2) 10)
        (= (total-energy-used) 0)

        (= (weight pkg1) 4)
        (= (weight pkg2) 3)
        (= (weight pkg3) 2)
        (= (weight pkg4) 1)
        (= (weight p_end) 0)

        (on pkg4 pkg3)
        (on pkg3 pkg2)
        (on pkg2 pkg1)
        (on pkg1 e1)
        (clear pkg4)
        (clear e2)

        (in-stack e1 e1)
        (in-stack e2 e2)
        (in-stack r1 r1)
        (in-stack r2 r2)
        (in-stack pkg1 e1)
        (in-stack pkg2 e1)
        (in-stack pkg3 e1)
        (in-stack pkg4 e1)

        (next-to-dispense pkg1)
        (next-to-dispense pkg2)
        (next-to-dispense pkg3)
        (order-seq pkg1 p_end)
        (order-seq pkg2 p_end)
        (order-seq pkg3 p_end)

        (connected l11 l12)
        (connected l12 l11)
        (connected l12 l13)
        (connected l13 l12)
        (connected l13 l14)
        (connected l14 l13)
        (connected l14 l15)
        (connected l15 l14)
        (connected l15 l16)
        (connected l16 l15)
        (connected l31 l32)
        (connected l32 l31)
        (connected l44 l45)
        (connected l45 l44)
        (connected l45 l46)
        (connected l46 l45)
        (connected l52 l53)
        (connected l53 l52)
        (connected l53 l54)
        (connected l54 l53)
        (connected l64 l65)
        (connected l65 l64)

        (connected l11 l21)
        (connected l21 l11)
        (connected l21 l31)
        (connected l31 l21)
        (connected l32 l42)
        (connected l42 l32)
        (connected l42 l52)
        (connected l52 l42)
        (connected l16 l26)
        (connected l26 l16)
        (connected l26 l36)
        (connected l36 l26)
        (connected l36 l46)
        (connected l46 l36)
        (connected l44 l54)
        (connected l54 l44)
        (connected l54 l64)
        (connected l64 l54)

        (adjacent-shelf l14 e1)
        (adjacent-shelf l52 e2)
        (adjacent-dispenser l65 d)
        (adjacent-charger l52 c)
    )
    (:goal
        (and
            (dispensed pkg1)
            (dispensed pkg2)
            (dispensed pkg3)
        )
    )
    (:metric minimize
        (total-energy-used)
    )
)